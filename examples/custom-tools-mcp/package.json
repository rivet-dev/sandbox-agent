{
  "name": "@sandbox-agent/example-custom-tools-mcp",
  "private": true,
  "type": "module",
  "scripts": {
    "build:mcp": "tsup src/mcp-server.ts --format cjs --platform node --target node18 --minify --out-dir dist",
    "start": "tsx src/upload-local-mcp.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "@sandbox-agent/example-shared": "workspace:*",
    "sandbox-agent": "workspace:*",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
